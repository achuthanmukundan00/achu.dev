{
  "path": "src/layouts/CaseStudyLayout.astro",
  "before": "---\n// CaseStudyLayout.astro — wrapper for /work/[slug] with editorial Pretext treatment.\nimport BaseLayout from \"./BaseLayout.astro\";\nimport PretextHeadline from \"@components/pretext/PretextHeadline.astro\";\nimport PretextPullQuote from \"@components/pretext/PretextPullQuote.astro\";\nimport PretextEditorialBlock from \"@components/pretext/PretextEditorialBlock.astro\";\nimport type { Project } from \"@data/projects\";\n\nexport interface Props {\n  project: Project;\n}\n\nconst { project } = Astro.props;\n\nconst accent = project.accent as \"blue\" | \"magenta\" | \"green\";\n\nconst accentBorder: Record<string, string> = {\n  blue: \"border-blue-400\",\n  magenta: \"border-purple-400\",\n  green: \"border-green-400\",\n};\n\n// Pull quotes per project\nconst quotes: Record<string, { text: string; attribution: string }> = {\n  relay: {\n    text: \"The agent should never know it's talking to a local model.\",\n    attribution: \"Relay design principle\",\n  },\n  synax: {\n    text: \"Transparency beats magic when you're running AI on your own machine.\",\n    attribution: \"Synax research direction\",\n  },\n  watchyourtemper: {\n    text: \"A creative world you can inhabit, not a portfolio link you can click.\",\n    attribution: \"watchyourtemper thesis\",\n  },\n  wytos: {\n    text: \"Your creative context should compound, not scatter.\",\n    attribution: \"wytOS design principle\",\n  },\n  \"temper-cloud\": {\n    text: \"Self-hosted infrastructure deserves production-grade rigour.\",\n    attribution: \"Temper Cloud design principle\",\n  },\n  \"secondhand-hub\": {\n    text: \"Fullstack ownership means every layer, from database to UI.\",\n    attribution: \"Secondhand Hub thesis\",\n  },\n};\n\nconst pullQuote = quotes[project.slug];\n---\n\n<BaseLayout title={project.title} description={project.description}>\n  <article class=\"space-y-16\">\n    <!-- ============================================================ -->\n    <!-- HEADER — Pretext editorial headline                            -->\n    <!-- ============================================================ -->\n    <header class=\"space-y-6\">\n      <a\n        href=\"/work\"\n        class=\"inline-flex items-center gap-2 text-sm text-neutral-500 hover:text-white transition-colors\"\n      >\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\"\n          fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"\n          stroke-linejoin=\"round\" aria-hidden=\"true\">\n          <path d=\"M19 12H5m7-7-7 7 7 7\" />\n        </svg>\n        All work\n      </a>\n\n      <!-- Editorial headline treatment -->\n      <PretextHeadline text={project.title} accent={accent} as=\"h1\" />\n\n      <p class=\"text-xl text-neutral-400 leading-relaxed max-w-3xl pl-6\">\n        {project.tagline}\n      </p>\n    </header>\n\n    <!-- ============================================================ -->\n    <!-- PULL QUOTE                                                     -->\n    <!-- ============================================================ -->\n    {pullQuote && (\n      <PretextPullQuote\n        quote={pullQuote.text}\n        attribution={pullQuote.attribution}\n        accent={accent}\n      />\n    )}\n\n    <!-- ============================================================ -->\n    <!-- EDITORIAL INTRO BLOCK                                          -->\n    <!-- ============================================================ -->\n    <PretextEditorialBlock accent={accent} title=\"At a glance\">\n      <p>{project.summary}</p>\n    </PretextEditorialBlock>\n\n    <!-- ============================================================ -->\n    <!-- SYNAX TERMINAL PREVIEW (closed alpha placeholder)              -->\n    <!-- ============================================================ -->\n    {\n      project.slug === \"synax\" && (\n        <section>\n          <h2 class=\"section-label\">Terminal Preview</h2>\n          <div class=\"max-w-3xl\">\n            <div class=\"relative rounded-lg border border-purple-400/20 bg-[#03080f] overflow-hidden\" style=\"box-shadow: inset 0 1px 0 rgba(192,132,252,0.08), 0 0 40px rgba(192,132,252,0.06);\">\n              <!-- Terminal chrome -->\n              <div class=\"flex items-center gap-2 px-4 py-3 border-b border-purple-400/10 bg-[#06060e]\">\n                <span class=\"w-3 h-3 rounded-full bg-[#ff5f56]\" aria-hidden=\"true\"></span>\n                <span class=\"w-3 h-3 rounded-full bg-[#ffbd2e]\" aria-hidden=\"true\"></span>\n                <span class=\"w-3 h-3 rounded-full bg-[#27c93f]\" aria-hidden=\"true\"></span>\n                <span class=\"ml-3 text-xs font-mono text-purple-300/50 uppercase tracking-[0.15em]\">Synax TUI — agent session</span>\n              </div>\n              <!-- Placeholder body -->\n              <div class=\"flex items-center justify-center min-h-[360px] p-8\">\n                <div class=\"text-center space-y-4\">\n                  <div class=\"w-16 h-16 mx-auto rounded-full border-2 border-dashed border-purple-400/20 flex items-center justify-center\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\"\n                      fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"\n                      stroke-linejoin=\"round\" class=\"text-purple-400/40\" aria-hidden=\"true\">\n                      <rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\" ry=\"2\" />\n                      <line x1=\"3\" y1=\"9\" x2=\"21\" y2=\"9\" />\n                      <line x1=\"9\" y1=\"21\" x2=\"9\" y2=\"9\" />\n                    </svg>\n                  </div>\n                  <div>\n                    <p class=\"text-sm font-mono text-purple-300/70 font-medium\">\n                      Terminal screenshot placeholder\n                    </p>\n                    <p class=\"mt-1 text-xs text-purple-300/40 font-mono\">\n                      Synax TUI preview — static image coming soon\n                    </p>\n                    <p class=\"mt-3 text-[0.62rem] text-purple-300/25 font-mono uppercase tracking-[0.15em]\">\n                      /assets/synax-terminal-preview.png\n                    </p>\n                  </div>\n                </div>\n              </div>\n              <!-- Status metadata footer -->\n              <div class=\"flex items-center justify-between px-4 py-2.5 border-t border-purple-400/10 bg-[#06060e]\">\n                <span class=\"text-[0.62rem] font-mono uppercase tracking-[0.12em] text-purple-300/40\">\n                  closed alpha · local-first agent research\n                </span>\n                <span class=\"inline-flex items-center gap-1.5 text-[0.62rem] font-mono uppercase tracking-[0.12em] text-purple-300/40\">\n                  <span class=\"w-1.5 h-1.5 rounded-full bg-purple-400/60\" aria-hidden=\"true\"></span>\n                  experimental\n                </span>\n              </div>\n            </div>\n          </div>\n        </section>\n      )\n    }\n\n    <!-- ============================================================ -->\n    <!-- CASE STUDY SECTIONS                                            -->\n    <!-- ============================================================ -->\n\n    <!-- Problem -->\n    <section>\n      <h2 class=\"section-label\">Problem</h2>\n      <div class=\"prose max-w-3xl\">\n        <p>{project.problem}</p>\n      </div>\n    </section>\n\n    <!-- Solution -->\n    <section>\n      <h2 class=\"section-label\">Solution</h2>\n      <div class=\"prose max-w-3xl\">\n        <p>{project.solution}</p>\n      </div>\n    </section>\n\n    <!-- What I Built -->\n    <section>\n      <h2 class=\"section-label\">What I Built</h2>\n      <div class=\"prose max-w-3xl\">\n        <p>{project.whatIBuilt}</p>\n      </div>\n    </section>\n\n    <!-- Extended sections (watchyourtemper) -->\n    {\n      project.extended && (\n        <div class=\"space-y-12\">\n          {Object.entries(project.extended).map(([key, content]) => (\n            <section>\n              <h2 class=\"section-label\">\n                {key === \"pressureTest\"\n                  ? \"PRESSURE TEST\"\n                  : key.charAt(0).toUpperCase() + key.slice(1).replace(/([A-Z])/g, \" $1\")}\n              </h2>\n              <div class=\"prose max-w-3xl\">\n                <p>{content}</p>\n              </div>\n            </section>\n          ))}\n        </div>\n      )\n    }\n\n    <!-- Technical Focus -->\n    <section>\n      <h2 class=\"section-label\">Technical &amp; Product Focus</h2>\n      <div class={`p-6 bg-[#0c0c14] border border-[#1e1e2e] rounded-lg max-w-3xl ${accentBorder[accent] ? `border-l-2` : \"\"}`}\n        style={accentBorder[accent] ? `border-left-color: var(--accent);` : \"\"}>\n        <p class=\"text-neutral-400 leading-relaxed whitespace-pre-line\">\n          {project.techFocus}\n        </p>\n      </div>\n    </section>\n\n    <!-- Links -->\n    {\n      project.links.length > 0 && (\n        <section>\n          <h2 class=\"section-label\">Links</h2>\n          <ul class=\"space-y-2\">\n            {project.links.map((link) => (\n              <li>\n                <a\n                  href={link.url}\n                  class={`inline-flex items-center gap-2 transition-colors underline underline-offset-2 ${\n                    link.url === \"#\"\n                      ? \"text-neutral-500 cursor-default\"\n                      : \"text-blue-400 hover:text-blue-300\"\n                  }`}\n                  {...(link.url === \"#\" ? { \"aria-disabled\": \"true\", tabindex: \"-1\" } : {})}\n                >\n                  {link.label}\n                  {link.url !== \"#\" && (\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\"\n                      fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"\n                      stroke-linejoin=\"round\" aria-hidden=\"true\">\n                      <path d=\"M7 17L17 7m0 0H7m10 0v10\" />\n                    </svg>\n                  )}\n                </a>\n              </li>\n            ))}\n          </ul>\n        </section>\n      )\n    }\n\n    <!-- Next Steps -->\n    <section>\n      <h2 class=\"section-label\">Next Steps</h2>\n      <div class=\"prose max-w-3xl\">\n        <p>{project.nextSteps}</p>\n      </div>\n    </section>\n\n    <!-- Back -->\n    <footer class=\"pt-8 border-t border-[#1e1e2e]\">\n      <a\n        href=\"/work\"\n        class=\"inline-flex items-center gap-2 text-sm text-neutral-500 hover:text-white transition-colors\"\n      >\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\"\n          fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"\n          stroke-linejoin=\"round\" aria-hidden=\"true\">\n          <path d=\"M19 12H5m7-7-7 7 7 7\" />\n        </svg>\n        Back to all work\n      </a>\n    </footer>\n  </article>\n</BaseLayout>\n",
