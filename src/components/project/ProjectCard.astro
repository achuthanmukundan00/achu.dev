---
import type { Project } from "@data/projects";

export interface Props {
  project: Project;
}

const { project } = Astro.props;

const accentColors: Record<string, string> = {
  blue: "border-l-blue-400",
  magenta: "border-l-purple-400",
  green: "border-l-green-400",
  brown: "border-l-amber-600",
  red: "border-l-red-500",
};

const borderColor = accentColors[project.accent] || "border-l-neutral-500";
---

<a
  href={`/work/${project.slug}`}
  class="project-card"
>
  <article class="space-y-3">
    <div class="flex items-start justify-between gap-3">
      <div class={`border-l-2 ${borderColor} pl-3`}>
        <p class="text-xs font-mono uppercase tracking-[0.12em] text-neutral-500 mb-1">
          {project.category}
        </p>
        <h3>{project.title}</h3>
      </div>
      <svg
        xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
        stroke-linejoin="round"
        class="text-neutral-600 group-hover:text-neutral-400 transition-colors shrink-0 mt-1"
        aria-hidden="true"
      >
        <path d="M7 17L17 7m0 0H7m10 0v10" />
      </svg>
    </div>

    <p class="text-sm text-neutral-500 font-mono">{project.tagline}</p>

    <p class="text-sm text-neutral-400 leading-relaxed line-clamp-3">
      {project.description}
    </p>

    <div class="flex flex-wrap gap-1.5 pt-1">
      {project.featured && (
        <span class="tag text-blue-300/70 border-blue-400/15">featured</span>
      )}
    </div>
  </article>
</a>
