---
// Footer.astro — minimal footer with key links.
import { links } from "@data/links";
import { site } from "@data/site";
---

<footer class="border-t border-neutral-800" role="contentinfo">
  <div class="mx-auto max-w-5xl px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-neutral-500">
    <div class="flex items-center gap-5">
      <a
        href={links.github}
        target="_blank"
        rel="noopener noreferrer me"
        class="hover:text-white transition-colors"
        aria-label="GitHub"
      >
        GitHub
      </a>
      <span aria-hidden="true" class="text-neutral-700">·</span>
      <a
        href={links.linkedin}
        target="_blank"
        rel="noopener noreferrer me"
        class="hover:text-white transition-colors"
        aria-label="LinkedIn"
      >
        LinkedIn
      </a>
      <span aria-hidden="true" class="text-neutral-700">·</span>
      <a
        href={`mailto:${links.email}`}
        class="hover:text-white transition-colors"
        aria-label="Send email"
      >
        Email
      </a>
      <span aria-hidden="true" class="text-neutral-700">·</span>
      <a
        href={links.watchyourtemper}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-white transition-colors"
      >
        wyt
      </a>
    </div>
    <p class="text-xs text-neutral-600">
      &copy; {new Date().getFullYear()} {site.fullName}
    </p>
  </div>
</footer>
