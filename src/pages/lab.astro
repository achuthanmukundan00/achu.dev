---
import BaseLayout from "@layouts/BaseLayout.astro";
import { links } from "@data/links";

const allRepos = [
  { name: "relay", url: links.relayRepo, desc: "OpenAI/Anthropic-compatible gateway for local llama.cpp inference." },
  { name: "synax", url: links.synaxRepo, desc: "Experimental local-first coding agent with TUI. Closed alpha." },
  { name: "suitcase", url: "https://suitcase-docs.pages.dev", desc: "Documentation, usage, and guides for the Suitcase project." },
  { name: "wytOS", url: links.wytosRepo, desc: "Local-first creative OS with structured memory and LLM assistance." },
  { name: "temper-cloud", url: links.temperCloudRepo, desc: "Self-hosted distributed storage and compute platform." },
  { name: "watchyourtemper", url: links.watchyourtemperRepo, desc: "Electronic music, events, merch, and visual world." },
  { name: "package-name-gen", url: links.packageNameGenRepo, desc: "Creative package name generator for npm." },
  { name: "AutoCareer", url: links.autoCareerRepo, desc: "AI job application copilot." },
  { name: "Resample-Lab", url: links.resampleLabRepo, desc: "Browser-based audio resampling with Paulstretch and spectral transforms." },
  { name: "wyt-SPA", url: "https://github.com/achuthanmukundan00/wyt-SPA", desc: "watchyourtemper single-page application." },
  { name: "Secondhand-Hub", url: "https://github.com/achuthanmukundan00/Secondhand-Hub", desc: "Fullstack marketplace — React, Flask, Docker, PostgreSQL." },
  { name: "Fractal-Explorer", url: "https://github.com/achuthanmukundan00/Fractal-Explorer", desc: "Unity game exploring the Mandelbrot set interactively." },
  { name: "INSIGHT", url: "https://github.com/achuthanmukundan00/INSIGHT", desc: "ML algorithm in Verilog with real-time polynomial fitting visualization." },
  { name: "DigitalDistortion", url: "https://github.com/achuthanmukundan00/DigitalDistortion", desc: "VST plugin for digital distortion in music production." },
  { name: "Capstone202425", url: "https://github.com/achuthanmukundan00/Capstone202425", desc: "University of Toronto capstone project." },
  { name: "ECE297-NoBS-GIS", url: "https://github.com/achuthanmukundan00/ECE297---NoBS-GIS", desc: "GIS application in C++ for ECE297." },
];
---

<BaseLayout
  title="Lab"
  description="All GitHub projects and links by Achu Mukundan."
>
  <header class="space-y-3 mb-10">
    <h1 class="text-4xl lg:text-5xl font-bold tracking-tight">Lab</h1>
    <p class="text-lg text-neutral-400 max-w-2xl leading-relaxed">
      All my GitHub projects and links in one place.
    </p>
  </header>

  <section>
    <div class="grid gap-2 sm:grid-cols-2">
      {allRepos.map((repo) => (
        <a
          href={repo.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-start gap-3 p-3 rounded-lg border border-transparent hover:border-neutral-800 hover:bg-[#111114] transition-all"
        >
          <div class="shrink-0 mt-0.5">
            <svg
              xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round"
              class="text-neutral-600 group-hover:text-neutral-400 transition-colors"
              aria-hidden="true"
            >
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
              <path d="M9 18c-4.51 2-5-2-7-2" />
            </svg>
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-medium text-white group-hover:text-blue-400 transition-colors truncate">
              {repo.name}
            </h3>
            <p class="text-xs text-neutral-500 leading-relaxed mt-0.5 line-clamp-1">
              {repo.desc}
            </p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
